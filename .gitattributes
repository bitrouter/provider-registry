# `registry.json` is generated by `bun run build-registry-json`, which always
# emits LF. Pin line endings so a Windows checkout (core.autocrlf=true) can't
# rewrite the committed artifact (or the YAML source) to CRLF and trip the
# `bun test` golden-in-sync check.
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.ts   text eol=lf
