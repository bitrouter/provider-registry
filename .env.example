# Credentials for the registry probe scripts (test-provider, fetch-models,
# check-new-models). Copy to `.env` and fill in. `.env` is gitignored —
# no credentials are ever committed.
#
# Convention (matches bitrouter-cloud): {PROVIDER_NAME_UPPER}_API_KEY and,
# where the base URL is not already known, {PROVIDER_NAME_UPPER}_API_BASE.
# Non-alphanumerics in the name become "_" (e.g. anon-a -> ANON_A_*).
#
# `check-new-models` resolves the base automatically for the providers
# marked "base: yaml" (BYOK `default_api_base`) and "base: public"
# (documented catalog) — for those you only need the API key. The base is
# REQUIRED only for the anonymous providers at the bottom.
#
# To find which providers already serve the newly-added models, the ones
# that matter most are flagged [opus-4.8], [minimax-m3], [qwen3.7-max].
# step-3.7-flash has no existing provider yet (StepFun is a new org).

# ── base known from yaml/public — supply API key only ────────────────────
ANTHROPIC_API_KEY=        # base: yaml   [opus-4.8]
MINIMAX_API_KEY=          # base: yaml   [minimax-m3]  (Anthropic-protocol endpoint)
ALIBABA_API_KEY=          # base: yaml   [qwen3.7-max]
CHUTES_API_KEY=           # base: public (unauthenticated catalog also works)
IONET_API_KEY=            # base: public (unauthenticated catalog also works)
DEEPSEEK_API_KEY=         # base: yaml
GOOGLE_API_KEY=           # base: yaml
MOONSHOTAI_API_KEY=       # base: yaml
OPENAI_API_KEY=           # base: yaml
XAI_API_KEY=              # base: yaml
XIAOMI_API_KEY=           # base: yaml
ZAI_API_KEY=              # base: yaml

# ── anonymous providers — base held server-side, supply key AND base ─────
ANON_A_API_KEY=           # [opus-4.8]
ANON_A_API_BASE=
WORLDROUTER_API_KEY=      # [opus-4.8] [qwen3.7-max]
WORLDROUTER_API_BASE=
REDPILL_API_KEY=          # [opus-4.8]
REDPILL_API_BASE=
TENCENT_API_KEY=          # [minimax-m3] [qwen3.7-max]
TENCENT_API_BASE=
AKASHML_API_KEY=          # [minimax-m3]
AKASHML_API_BASE=
ANON_B_API_KEY=
ANON_B_API_BASE=
TINFOIL_API_KEY=
TINFOIL_API_BASE=
